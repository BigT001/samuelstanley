datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ClientSite {
  id                String      @id @default(uuid())
  name              String
  url               String
  apiKey            String      @unique
  active            Boolean     @default(true)
  status            String      @default("unknown")
  lastPing          DateTime?
  responseTime      Int?
  sslExpiry         DateTime?
  webhookUrl        String?
  notificationEmail String?
  logs              ClientLog[]
  createdAt         DateTime    @default(now())
}

model ClientLog {
  id        String     @id @default(uuid())
  clientId  String
  client    ClientSite @relation(fields: [clientId], references: [id], onDelete: Cascade)
  level     String     // info, warn, error, fatal
  message   String
  stack     String?
  metadata  String?    // JSON details
  timestamp DateTime   @default(now())
}

model AlertEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  sites     String[] // ClientSite IDs linked to this email
  createdAt DateTime @default(now())
}

model PostMetric {
  slug      String   @id
  likes     Int      @default(0)
  shares    Int      @default(0)
  comments  String   @default("[]") // JSON string of comments list
  updatedAt DateTime @updatedAt
}

model GithubProject {
  id           String   @id @default(cuid())
  repoName     String   @unique     // e.g. "samuelstanley"
  fullName     String               // e.g. "BigT001/samuelstanley"
  visible      Boolean  @default(false) // Toggle: show on public portfolio
  displayTitle String?              // Override repo name for display
  displayDesc  String?              // Override repo description
  displayTags  String[] @default([]) // Custom tech tags
  statusLabel  String?              // "LIVE", "ACTIVE", "COMPLETED", "ONGOING"
  pinnedOrder  Int?                 // Optional manual sort order (lower = higher)
  stars        Int      @default(0)
  forks        Int      @default(0)
  language     String?
  repoUrl      String?
  homepage     String?
  isPrivate    Boolean  @default(false)
  lastPushedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
